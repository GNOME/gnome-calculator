#: data/org.gnome.calculator.gschema.xml:31
msgid "Accuracy value"
msgstr "ຄ່າຄວາມແມ່ນຍຳ"

#: data/org.gnome.calculator.gschema.xml:32
msgid "The number of digits displayed after the numeric point"
msgstr "ຈຳນວນຕົວເລກທີ່ສະແດງຫຼັງຈຸດທົດສະນິຍົມ"

#: data/org.gnome.calculator.gschema.xml:37
msgid "Word size"
msgstr "ຂະໜາດຄຳສັບ"

#: data/org.gnome.calculator.gschema.xml:38
msgid "The size of the words used in bitwise operations"
msgstr "ຂະໜາດຂອງຄຳສັບທີ່ໃຊ້ໃນການດຳເນີນການລະດັບບິດ"

#: data/org.gnome.calculator.gschema.xml:43
msgid "Numeric Base"
msgstr "ຖານເລກ"

#: data/org.gnome.calculator.gschema.xml:44
msgid "The numeric base"
msgstr "ຖານຂອງຕົວເລກ"

#: data/org.gnome.calculator.gschema.xml:48
msgid "Show Thousands Separators"
msgstr "ສະແດງຕົວຂັ້ນຫຼັກພັນ"

#: data/org.gnome.calculator.gschema.xml:49
msgid "Indicates whether thousands separators are shown in large numbers."
msgstr "ບົ່ງບອກວ່າຈະສະແດງຕົວຂັ້ນຫຼັກພັນໃນຕົວເລກໃຫຍ່ຫຼືບໍ່."

#: data/org.gnome.calculator.gschema.xml:53
msgid "Show Trailing Zeroes"
msgstr "ສະແດງເລກສູນຕໍ່ທ້າຍ"

#: data/org.gnome.calculator.gschema.xml:54
msgid ""
"Indicates whether any trailing zeroes after the numeric point should be "
"shown in the display value."
msgstr "ບົ່ງບອກວ່າຈະສະແດງເລກສູນຕໍ່ທ້າຍຫຼັງຈຸດທົດສະນິຍົມໃນຄ່າທີ່ສະແດງຜົນຫຼືບໍ່."

#: data/org.gnome.calculator.gschema.xml:58
msgid "Number format"
msgstr "ຮູບແບບຕົວເລກ"

#: data/org.gnome.calculator.gschema.xml:59
msgid "The format to display numbers in"
msgstr "ຮູບແບບສຳລັບການສະແດງຜົນຕົວເລກ"

#: data/org.gnome.calculator.gschema.xml:63
msgid "Angle units"
msgstr "ຫົວໜ່ວຍມຸມ"

#: data/org.gnome.calculator.gschema.xml:64
msgid "The angle units to use"
msgstr "ຫົວໜ່ວຍມຸມທີ່ຈະໃຊ້"

#: data/org.gnome.calculator.gschema.xml:68
msgid "Currency update interval"
msgstr "ໄລຍະເວລາອັບເດດສະກຸນເງິນ"

#: data/org.gnome.calculator.gschema.xml:69
msgid ""
"How often the currency exchange rates should be updated. A value of 0 means "
"the currency exchange rates won't be fetched from the network at all."
msgstr "ຄວາມຖີ່ໃນການອັບເດດອັດຕາແລກປ່ຽນເງິນຕາ. ຄ່າ 0 ໝາຍຄວາມວ່າອັດຕາແລກປ່ຽນເງິນຕາຈະບໍ່ຖືກດຶງມາຈາກເຄືອຂ່າຍເລີຍ."

#: data/org.gnome.calculator.gschema.xml:73
msgid "Currency display"
msgstr "ການສະແດງຜົນສະກຸນເງິນ"

#: data/org.gnome.calculator.gschema.xml:74
msgid ""
"Indicates whether to show currency code, currency name or both of them in "
"the converter."
msgstr "ບົ່ງບອກວ່າຈະສະແດງລະຫັດສະກຸນເງິນ, ຊື່ສະກຸນເງິນ ຫຼື ທັງສອງຢ່າງໃນຕົວປ່ຽນຫົວໜ່ວຍ."

#: data/org.gnome.calculator.gschema.xml:78
msgid "Enabled completions"
msgstr "ເປີດໃຊ້ການເຮັດໃຫ້ສົມບູນ"

#: data/org.gnome.calculator.gschema.xml:79
msgid ""
"The types of completion proposals to be shown in the auto-completion list."
msgstr "ປະເພດຂອງການສະເໜີແນະເພື່ອເຮັດໃຫ້ສົມບູນທີ່ຈະສະແດງໃນລາຍການເຮັດໃຫ້ສົມບູນອັດຕະໂນມັດ."

#: data/org.gnome.calculator.gschema.xml:83
msgid "Favorite currencies"
msgstr "ສະກຸນເງິນທີ່ມັກ"

#: data/org.gnome.calculator.gschema.xml:84
msgid "The favorite currencies to be shown at the top of the currency list."
msgstr "ສະກຸນເງິນທີ່ມັກທີ່ຈະສະແດງຢູ່ເທິງສຸດຂອງລາຍການສະກຸນເງິນ."

#: data/org.gnome.calculator.gschema.xml:88
msgid "Button mode"
msgstr "ໂໝດປຸ່ມ"

#: data/org.gnome.calculator.gschema.xml:89
